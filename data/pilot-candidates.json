OUNDARY"},{"acceptance":"标准正文并完成页级精确引文","document_role":"PAN原丝标准或技术原件","evidence_area_id":"precursor","expected_claim":"PAN原丝结构、形态与作为碳纤维前驱体的边界","slot_id":"CF-PRECURSOR-01","status":"lead_verified_document_pending_registration","target_gap_id":"CF-GAP-PRECURSOR"},{"acceptance":"标准、科研机构、项目或企业法定原件；不得用PAN路线外推","document_role":"沥青基前驱体路线原件","evidence_area_id":"precursor","expected_claim":"沥青基碳纤维前驱体、工艺和产品边界","slot_id":"CF-PRECURSOR-02","status":"planned","target_gap_id":"CF-GAP-PRECURSOR"},{"acceptance":"正式原件；若国内产业化证据缺失应明确标记而非补造","document_role":"粘胶基或其他前驱体路线原件","evidence_area_id":"precursor","expected_claim":"非PAN、非沥青路线的存在、适用范围和状态","slot_id":"CF-PRECURSOR-03","status":"planned","target_gap_id":"CF-GAP-PRECURSOR"},{"acceptance":"企业环评、项目验收、问询回复、专利或同行评审原件，至少含可引用过程条件","document_role":"预氧化与碳化工艺原件","evidence_area_id":"manufacturing-process","expected_claim":"预氧化、碳化过程、关键条件和相互关系","slot_id":"CF-PROCESS-01","status":"registered_cited_scope_insufficient","target_gap_id":"CF-GAP-PROCESS"},{"acceptance":"设备技术文件、环评、招股书或项目验收原件","document_role":"制造设备与产线原件","evidence_area_id":"manufacturing-process","expected_claim":"氧化炉、碳化炉、表面处理、上浆和卷绕等设备配置","slot_id":"CF-PROCESS-02","status":"planned","target_gap_id":"CF-GAP-PROCESS"},{"acceptance":"法定披露、环评、验收或正式研究资料；估算与实测必须区分","document_role":"产能、良率、能耗或周期原件","evidence_area_id":"manufacturing-process","expected_claim":"制造过程的量化产能、良率、能耗或周期","slot_id":"CF-PROCESS-03","status":"planned","target_gap_id":"CF-GAP-PROCESS"},{"acceptance":"标准正文并完成页级精确引文","document_role":"表面处理与上浆标准原件","evidence_area_id":"manufacturing-process","expected_claim":"上浆环节、上浆剂含量和测试边界","slot_id":"CF-PROCESS-04","status":"lead_verified_document_pending_registration","target_gap_id":"CF-GAP-PROCESS"},{"acceptance":"国家或行业标准正文，保留样品和测试条件","document_role":"碳纤维产品与性能标准","evidence_area_id":"product-forms","expected_claim":"碳纤维、单丝和浸胶纱等产品与性能测试边界","slot_id":"CF-PRODUCT-01","status":"lead_verified_document_pending_registration","target_gap_id":"CF-GAP-PRODUCTS"},{"acceptance":"企业年报、招股书、问询回复或产品标准原件；企业整体